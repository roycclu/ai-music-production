# Anthropic API key (required)
ANTHROPIC_API_KEY=YOUR_ANTHROPIC_API_KEY_HERE

# MiniMax API credentials (required for audio/video generation)
MINIMAX_API_KEY=YOUR_MINIMAX_API_KEY_HERE
MINIMAX_GROUP_ID=YOUR_MINIMAX_GROUP_ID_HERE

# Set to true to skip MiniMax API calls and use simulated responses
# Useful for testing the Claude creative pipeline without spending credits
DEMO_MODE=false

# Optional: override MiniMax base URL for different regions
# MINIMAX_BASE_URL=https://api.minimax.chat/v1
