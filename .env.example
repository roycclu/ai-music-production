# Anthropic API key (required)
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# ── Music provider chain ────────────────────────────────────────────────────────
# Comma-separated list of providers to try in order.  The first success is used.
# Supported values: minimax, elevenlabs, audiocraft, demo
# If unset, providers are inferred from which API keys are present.
#
# Examples:
#   MUSIC_PROVIDER=minimax,elevenlabs,audiocraft   # full chain with local fallback
#   MUSIC_PROVIDER=audiocraft                      # local only (no API keys needed)
#   MUSIC_PROVIDER=demo                            # simulated responses for dev/CI
MUSIC_PROVIDER=minimax,elevenlabs

# ── MiniMax (primary music/video generation) ───────────────────────────────────
# Required for real audio and video generation via MiniMax music-2.5 / video-01.
MINIMAX_API_KEY=your-minimax-api-key-here
MINIMAX_GROUP_ID=your-minimax-group-id-here

# Optional: override MiniMax base URL for different regions
# MINIMAX_BASE_URL=https://api.minimax.io/v1

# ── ElevenLabs (fallback music generation) ────────────────────────────────────
# Used when MiniMax raises an error.  Calls /v1/music (song generation) with
# fallback to /v1/sound-generation (≤ 22 s instrumental).
# Leave blank to skip ElevenLabs and rely on other providers only.
ELEVENLABS_API_KEY=your-elevenlabs-api-key-here

# Optional: override ElevenLabs base URL
# ELEVENLABS_BASE_URL=https://api.elevenlabs.io

# ── AudioCraft / MusicGen (local, offline) ────────────────────────────────────
# Meta's MusicGen runs entirely on your machine — no API key required.
# Install first:  pip install audiocraft soundfile
# Then add "audiocraft" to MUSIC_PROVIDER (e.g. MUSIC_PROVIDER=minimax,audiocraft).
#
# Model choices (set AUDIOCRAFT_MODEL):
#   facebook/musicgen-small   ~  300 MB  — fast, good for prototyping
#   facebook/musicgen-medium  ~  1.5 GB  — better quality
#   facebook/musicgen-large   ~  3.3 GB  — best quality
#   facebook/musicgen-melody  ~  1.5 GB  — can condition on a melody
AUDIOCRAFT_MODEL=facebook/musicgen-small
AUDIOCRAFT_DEVICE=cpu
AUDIOCRAFT_DURATION=30

# ── Demo / development mode ────────────────────────────────────────────────────
# Set to true to skip all API calls and use simulated responses.
# Useful for testing the Claude creative pipeline without spending credits.
# Alternatively add "demo" to MUSIC_PROVIDER for the same effect.
DEMO_MODE=false
