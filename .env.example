# Anthropic API key (required)
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# ── MiniMax (primary music/video generation) ───────────────────────────────────
# Required for real audio and video generation via MiniMax music-01 / video-01.
MINIMAX_API_KEY=your-minimax-api-key-here
MINIMAX_GROUP_ID=your-minimax-group-id-here

# Optional: override MiniMax base URL for different regions
# MINIMAX_BASE_URL=https://api.minimax.chat/v1

# ── ElevenLabs (fallback music/vocal generation) ──────────────────────────────
# Used automatically when MiniMax returns an error.  If both providers fail the
# pipeline stops.  Leave blank to skip ElevenLabs and rely on MiniMax only.
ELEVENLABS_API_KEY=your-elevenlabs-api-key-here

# ElevenLabs voice ID to use for TTS-based vocal fallback.
# Default: Adam (pNInz6obpgDQGcFmaJgB) — warm male voice that suits folk/soul.
# Browse voices at https://elevenlabs.io/voice-library and paste any voice ID here.
# ELEVENLABS_VOICE_ID=pNInz6obpgDQGcFmaJgB

# Optional: override ElevenLabs base URL
# ELEVENLABS_BASE_URL=https://api.elevenlabs.io

# ── Demo / development mode ────────────────────────────────────────────────────
# Set to true to skip all API calls and use simulated responses.
# Useful for testing the Claude creative pipeline without spending credits.
DEMO_MODE=false
